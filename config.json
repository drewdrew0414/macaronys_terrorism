{
  "schema_version": 4,
  "project": {
    "name": "Macaronys Assignment Backend",
    "timezone": "Asia/Seoul",
    "example_html": "examples/integration_setup.html",
    "secret_policy": "runtime secrets are kept in .env only; config.json contains public wiring metadata"
  },
  "quality_controls": {
    "ui_ux": {
      "target_users": [
        "middle_school_students",
        "high_school_students",
        "teachers"
      ],
      "interaction_model": "Discord slash commands with autocomplete, ephemeral feedback for private results, and paginated embeds for dense information.",
      "minimal_surface": [
        "student commands expose only daily school workflows",
        "dangerous admin commands require console channel and confirmation words",
        "meal and timetable commands do not ask for unnecessary input"
      ],
      "design_language": {
        "primary_component": "discord_embed",
        "navigation": "pagination_buttons",
        "tone": "short_korean_labels",
        "colors": {
          "primary": "0x5865F2",
          "success": "0x57F287",
          "warning": "0xFEE75C",
          "danger": "0xED4245"
        }
      }
    },
    "software_architecture": {
      "folder_policy": {
        "routers": "HTTP API routes only",
        "services": "business logic and external integrations",
        "schemas": "request and response DTOs",
        "database": "schema and migration-oriented SQL",
        "tests": "unit and integration tests"
      },
      "readme_required_sections": [
        "setup",
        "run",
        "discord_commands",
        "architecture",
        "security",
        "tests",
        "commit_policy"
      ],
      "version_control": {
        "track": [
          "source",
          "tests",
          "safe templates",
          "documentation"
        ],
        "ignore": [
          ".env",
          "runtime data",
          "virtual environments",
          "cache files"
        ],
        "commit_message_style": "type(scope): imperative summary"
      }
    },
    "security": {
      "severity_scale": {
        "4": "credential exposure, unauthenticated worker/admin APIs, destructive command bypass",
        "3": "over-privileged bot permissions, missing audit logs, broad data exposure",
        "2": "weak validation, missing timeout, unsafe defaults",
        "1": "minor hardening or documentation gaps"
      },
      "controls": [
        "no runtime secrets in config.json",
        "worker APIs require X-Worker-Token",
        "admin commands are restricted to staff channels and Discord administrators",
        "bot invite uses least-privilege permissions instead of full admin permission",
        "moderation actions are written to audit tables",
        "NEIS and AI external calls use bounded timeouts"
      ]
    }
  },
  "backend": {
    "base_url": "http://localhost:8000",
    "docs_url": "http://localhost:8000/docs",
    "health_path": "/health",
    "database": {
      "mode": "external_postgresql_only",
      "schema_file": "database/schema.sql",
      "tables": [
        "school_classes",
        "users",
        "sources",
        "assignment_candidates",
        "assignments",
        "ai_jobs",
        "notification_rules",
        "notifications",
        "discord_guilds",
        "discord_user_links",
        "discord_channel_mappings",
        "discord_moderation_logs",
        "clubs",
        "club_members",
        "voice_rooms",
        "command_logs",
        "team_projects",
        "team_project_members",
        "peer_reviews",
        "team_join_requests",
        "registrations",
        "votes",
        "vote_choices",
        "vote_responses"
      ]
    },
    "ai": {
      "model_provider": "ollama",
      "default_model": "gemma3:4b",
      "default_execution_mode": "local",
      "local_worker": {
        "enabled": true,
        "start_script": "./start.sh",
        "behavior": "start.sh detects Ollama, lets the user choose an installed model, and starts local workers up to AI_WORKER_CONCURRENCY"
      },
      "server_parallel_queue": {
        "enabled": false,
        "enable_with_env": "SERVER_OLLAMA_ENABLED=true and AI_EXECUTION_MODE=server",
        "concurrency_env": "AI_WORKER_CONCURRENCY"
      }
    }
  },
  "run": {
    "unix_script": "./start.sh",
    "windows_script": "start.bat",
    "default_mode": "all",
    "supported_modes": [
      {
        "name": "all",
        "description": "Default. Start Docker API, Docker Discord bot, and local Ollama AI worker."
      },
      {
        "name": "docker",
        "description": "Start Docker API and Docker Discord bot. Local worker is not started."
      },
      {
        "name": "api-only",
        "description": "Start only the Docker API service."
      },
      {
        "name": "local",
        "description": "Run FastAPI directly from the local Python virtual environment."
      },
      {
        "name": "worker",
        "description": "Run the local Ollama/Gemma AI worker in the foreground."
      },
      {
        "name": "discord-bot",
        "description": "Run the Discord slash-command bot locally in the foreground."
      }
    ]
  },
