APP_NAME=Macaronys Assignment Backend
APP_ENV=development
APP_TIMEZONE=Asia/Seoul
AUTO_CREATE_TABLES=true

# Put the real external PostgreSQL URL only in .env.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB_NAME?sslmode=require

# local: API stores AI jobs; start.sh runs a local worker that uses local Ollama/Gemma.
# server: reserved for a VPS Ollama/Gemma queue. It stays disabled unless SERVER_OLLAMA_ENABLED=true.
AI_EXECUTION_MODE=local
SERVER_OLLAMA_ENABLED=false

OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=gemma3:4b
OLLAMA_AUTO_PULL=false
OLLAMA_TIMEOUT_SECONDS=300

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
WORKER_TOKEN=replace-with-random-worker-token
WORKER_CLAIM_TIMEOUT_SECONDS=900
SERVER_BASE_URL=http://localhost:8000
AI_JOB_POLL_SECONDS=2
AI_WORKER_CONCURRENCY=2

UPLOAD_DIR=data/uploads
MAX_UPLOAD_SIZE_MB=1024

NOTIFICATION_DISPATCH_BATCH_SIZE=20
DISCORD_WEBHOOK_URL=
DISCORD_BOT_TOKEN=
DISCORD_SYNC_COMMANDS=true
# NEIS 학교 정보 API (https://open.neis.go.kr 에서 발급)
NEIS_API_KEY=
NEIS_ATPT_CODE=R10
NEIS_SCHOOL_CODE=8750829

LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000
