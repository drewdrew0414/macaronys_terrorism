# ─────────────────────────────────────────────────────────────────
#  .env.example  —  환경 변수 설정 템플릿
#  이 파일을 복사해 .env로 저장하고 값을 채우세요.
#  cp .env.example .env
# ─────────────────────────────────────────────────────────────────

# Ollama 서버 주소 (원격 서버 사용 시 변경, 기본: 로컬)
OLLAMA_HOST=http://localhost:11434

# Whisper 음성 인식 모델 크기
# tiny(최소) → base → small → medium → large(최고 품질)
WHISPER_MODEL=base

# 요약 파일 자동 저장 경로 (추후 기능)
EXPORT_DIR=./exports

# YouTube Data API 키 (선택사항 — 없으면 무료 자막 API 사용)
YOUTUBE_API_KEY=
